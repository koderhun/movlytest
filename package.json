{
  "name": "gulpstarter",
  "description": "Frontend start kit",
  "author": "another",
  "license": "MIT",
  "scripts": {
    "dev": "gulp",
    "build": "gulp prod --production",
    "build:views": "gulp views --production",
    "build:styles": "gulp styles --production",
    "build:scripts": "gulp scripts --production",
    "build:images": "gulp images --production",
    "build:webp": "gulp webp --production",
    "build:sprites": "gulp sprites --production",
    "build:fonts": "gulp fonts --production",
    "build:favicons": "gulp favicons --production",
    "build:gzip": "gulp gzip --production",
    "lint:styles": "stylelint \"src/**/*.scss\" --syntax=scss",
    "lint:styles --fix": "stylelint \"src/**/*.scss\" --syntax=scss --fix",
    "lint:scripts": "eslint --color ./src/blocks",
    "lint:scripts --fix": "eslint --fix --color ./src/blocks",
    "deploy": "gulp prod --production && gulp gzip --production && gulp deploy"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/eslint-parser": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/register": "^7.25.0",
    "autoprefixer": "^10.4.20",
    "babel-loader": "^9.2.1",
    "browser-sync": "^3.0.4",
    "del": "^6.1.0",
    "gulp": "^4.0.2",
    "gulp-clean-css": "^4.3.0",
    "gulp-debug": "^4.0.0",
    "gulp-file-include": "^2",
    "gulp-gh-pages": "^0.5.4",
    "gulp-htmlmin": "^5.0.1",
    "gulp-if": "^3.0.0",
    "gulp-imagemin": "7.1.0",
    "gulp-newer": "^1.4.0",
    "gulp-plumber": "^1.2.1",
    "gulp-postcss": "^10.0.0",
    "gulp-real-favicon": "^0.3.2",
    "gulp-rename": "^2.0.0",
    "gulp-replace": "^1.1.4",
    "gulp-sass": "^5.1.0",
    "gulp-sharp": "^0.1.0",
    "gulp-sourcemaps": "^2.6.5",
    "gulp-watch": "^5.0.1",
    "gulp-webp": "^4.0.1",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "localtunnel": "^2.0.2",
    "postcss": "^8.4.40",
    "prettier-plugin-tailwindcss": "^0.5.0",
    "require-dir": "^1.2.0",
    "sass": "^1.78.0",
    "sharp": "^0.35.2",
    "stylelint": "^16.7.0",
    "stylelint-order": "^6.0.0",
    "svgo": "^4.0.1",
    "tailwindcss": "^3.4.8",
    "webpack": "^5.93.0",
    "webpack-stream": "^7.0.0",
    "yargs": "^17.7.2"
  },
  "dependencies": {
    "jquery": "^3.7.1",
    "swiper": "^11.1.14"
  },
  "lint-staged": {
    "!(_*).scss": [
      "stylelint --fix --color --config ./.stylelintrc"
    ],
    "*.js": [
      "eslint --fix --color"
    ]
  },
  "browserslist": [
    "last 1 version",
    "> 1%",
    "IE 10"
  ]
}
